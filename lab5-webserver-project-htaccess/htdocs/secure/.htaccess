# =============================================================================
# LAB 5: Secure Directory .htaccess - Basic Authentication
# =============================================================================
# Protects /secure/ - users must enter username/password from .htpasswd file.
# AuthUserFile = full path to .htpasswd inside the container.
# =============================================================================

AuthType Basic
AuthName "Restricted Area"
AuthUserFile /usr/local/apache2/htdocs/secure/.htpasswd
Require valid-user
